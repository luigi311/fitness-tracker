<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
    <id>com.luigi311.fitness-tracker</id>
    <name>Fitness Tracker</name>
    <summary>Open source fitness tracker</summary>
    <metadata_license>CC0-1.0</metadata_license>
    <project_license>GPL-3.0</project_license>
    <supports>
        <control>keyboard</control>
        <control>pointing</control>
        <control>touch</control>
    </supports>
    <requires>
        <display_length side="shortest" compare="ge">250</display_length>
        <display_length side="longest" compare="ge">400</display_length>
    </requires>
    <developer id="com.luigi311">
        <name>
            Luigi311
        </name>
    </developer>
    <url type="homepage">https://github.com/luigi311/fitness-tracker</url>
    <url type="vcs-browser">https://github.com/luigi311/fitness-tracker</url>
    <url type="bugtracker">https://github.com/luigi311/fitness-tracker/issues</url>
    <description>
        <p>An open-source application for tracking sensor data from Bluetooth Low Energy (BLE)
            devices in real time, recording sessions, and visualizing your workout history.</p>
    </description>
